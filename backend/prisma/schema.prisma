// Schema do banco de dados - Sistema de Pedidos de Marmitas Congeladas
// Modelagem baseada nas HU001-HU004 do documento de produto

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- ADMIN (HU002 - acesso restrito, RN001) ----------
enum CargoAdmin {
  DONA
  COZINHA
  ATENDIMENTO
}

model Admin {
  id        String     @id @default(uuid())
  nome      String
  email     String     @unique
  senhaHash String
  cargo     CargoAdmin @default(DONA)
  createdAt DateTime   @default(now())
}

// Convite pendente pra alguém entrar na equipe (RN001 estendida)
model AdminConvite {
  id       String     @id @default(uuid())
  email    String
  cargo    CargoAdmin @default(ATENDIMENTO)
  token    String     @unique
  aceitoEm DateTime?
  expiraEm DateTime
  createdAt DateTime  @default(now())
}

// ---------- CLIENTE (HU001, HU004 - histórico) ----------
model Cliente {
  id        String   @id @default(uuid())
  nome      String
  telefone  String   @unique
  endereco  String
  senhaHash String? // null = nunca criou conta, sempre pediu como convidado
  createdAt DateTime @default(now())

  pedidos     Pedido[]
  assinaturas Assinatura[]
}

// ---------- CARDÁPIO (HU002) ----------
model Cardapio {
  id            String   @id @default(uuid())
  semanaInicio  DateTime
  semanaFim     DateTime
  ativo         Boolean  @default(true)
  createdAt     DateTime @default(now())

  itens ItemCardapio[]
}

model ItemCardapio {
  id              String   @id @default(uuid())
  cardapioId      String
  sabor           String
  descricao       String?
  preco           Decimal  @db.Decimal(10, 2)
  qtdDisponivel   Int
  controlaEstoque Boolean  @default(true)
  tags            String[] @default([])
  ativo           Boolean  @default(true)

  cardapio    Cardapio     @relation(fields: [cardapioId], references: [id])
  itensPedido ItemPedido[]
}

// ---------- CUPOM DE DESCONTO ----------
enum TipoDesconto {
  PERCENTUAL
  FIXO
}

model Cupom {
  id          String       @id @default(uuid())
  codigo      String       @unique
  tipo        TipoDesconto
  valor       Decimal      @db.Decimal(10, 2)
  ativo       Boolean      @default(true)
  validoAte   DateTime?
  usosMaximos Int?
  usosAtuais  Int          @default(0)
  createdAt   DateTime     @default(now())

  pedidos Pedido[]
}

// ---------- CONFIGURAÇÃO DO NEGÓCIO (linha única) ----------
model ConfiguracaoNegocio {
  id                  String   @id @default(uuid())
  nomeNegocio         String   @default("Dona Adilma")
  telefone            String   @default("")
  endereco            String   @default("")
  horarios            Json     @default("{}")
  pagamentosAceitos   String[] @default(["PIX", "CARTAO", "DINHEIRO"])
  notificarNovoPedido Boolean  @default(true)
  resumoSemanalEmail  Boolean  @default(false)
  updatedAt           DateTime @updatedAt
}

// ---------- ASSINATURA (planos recorrentes) ----------
enum Periodicidade {
  SEMANAL
  QUINZENAL
  MENSAL
}

enum StatusAssinatura {
  ATIVA
  PAUSADA
  CANCELADA
}

model Assinatura {
  id              String           @id @default(uuid())
  clienteId       String
  periodicidade   Periodicidade
  status          StatusAssinatura @default(ATIVA)
  itensPadrao     Json // [{ itemCardapioId, quantidade }]
  formaPagamento  FormaPagamento
  tipoEntrega     TipoEntrega      @default(ENTREGA)
  proximoPedidoEm DateTime
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  cliente Cliente  @relation(fields: [clienteId], references: [id])
  pedidos Pedido[]
}

// ---------- PEDIDO (HU001, HU002, HU003) ----------
enum StatusPedido {
  RECEBIDO
  EM_PREPARACAO
  PRONTO
  SAIU_ENTREGA
  ENTREGUE
}

enum FormaPagamento {
  PIX
  CARTAO
  DINHEIRO
}

enum StatusPagamento {
  PENDENTE
  PAGO
  CANCELADO
}

enum TipoEntrega {
  ENTREGA
  RETIRADA
}

model Pedido {
  id              String          @id @default(uuid())
  clienteId       String
  status          StatusPedido    @default(RECEBIDO)
  formaPagamento  FormaPagamento
  statusPagamento StatusPagamento @default(PENDENTE)
  tipoEntrega     TipoEntrega     @default(ENTREGA)
  taxaEntrega     Decimal         @default(0) @db.Decimal(10, 2)
  cupomId         String?
  valorDesconto   Decimal         @default(0) @db.Decimal(10, 2)
  valorTotal      Decimal         @db.Decimal(10, 2)
  observacoes     String?
  assinaturaId    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  cliente    Cliente      @relation(fields: [clienteId], references: [id])
  itens      ItemPedido[]
  cupom      Cupom?       @relation(fields: [cupomId], references: [id])
  assinatura Assinatura?  @relation(fields: [assinaturaId], references: [id])
}

// ---------- ITEM DO PEDIDO (controle unitário - RN005) ----------
enum StatusUnidade {
  PREPARANDO
  PRONTA
}

model ItemPedido {
  id             String        @id @default(uuid())
  pedidoId       String
  itemCardapioId String
  quantidade     Int
  statusUnidade  StatusUnidade @default(PREPARANDO)

  pedido       Pedido       @relation(fields: [pedidoId], references: [id])
  itemCardapio ItemCardapio @relation(fields: [itemCardapioId], references: [id])
}
